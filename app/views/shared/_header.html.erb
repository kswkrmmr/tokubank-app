<header>
  <nav class="navbar navbar-expand-lg navbar-light bg-light">
    <div class="container-fluid">
      
      <%= link_to '/', class: 'navbar-brand' do %>
        <%= image_tag 'logo.png', height: 60 %>
      <% end %>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          
          <li class="nav-item">
            <%= link_to "Home", root_path, class: "nav-link" %>
          </li>

          <% if logged_in? %>

            <li class="nav-item">
              <%= link_to "徳を積む", good_deeds_new_path, class: "nav-link" %>
            </li>

            <li class="nav-item">
              <%= link_to "ログアウト", logout_path, method: :delete, class: "nav-link", data: { turbo_method: :delete }  %>
            </li>
          <% else %>
            <li class="nav-item">
              <%= link_to "ログイン", login_path, class: "nav-link" %>
            </li>

            <li class="nav-item">
              <%= link_to "新規登録", new_user_path, class: "nav-link" %>
            </li>
          <% end %>

        </ul>
      </div>
    </div>
  </nav>
</header>